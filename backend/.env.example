# Copy this file to .env and fill in the real values locally.
# Spring Boot reads backend/.env because application.properties imports it.
# Use APP_FRONTEND_URL to point OAuth redirects/CORS at your deployed frontend.

DB_USERNAME=root
DB_PASSWORD=root
JWT_SECRET=change-this-secret-in-your-local-backend-env-file
APP_FRONTEND_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

